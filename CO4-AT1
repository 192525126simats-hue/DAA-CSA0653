edges=[
    (0,1,2),
    (0,2,3),
    (1,2,1),
    (1,3,4),
    (2,3,5)]
n=4
edges.sort(key=lambda x: x[2])
parent=[0,1,2,3]
cost=0
def find(x):
    if parent[x] == x:
        return x
    return find(parent[x])
print("Edges in MST:")
for u, v, w in edges:
    if find(u) != find(v):
        print(u, "-", v, "=", w)
        cost += w
        parent[find(u)] = find(v)
print("Total cost =", cost)

Investments=[
("A", 20000, 25000),
    ("B", 30000, 40000),
    ("C", 40000, 50000),
    ("D", 50000, 70000)
]
budget = 80000
investments.sort(key=lambda x: x[2] / x[1], reverse=True)
selected = []
total_return = 0
for name, capital, ret in investments:
    if budget >= capital:
        selected.append(name)
        budget -= capital
        total_return += ret
